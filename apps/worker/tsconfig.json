{
  "compilerOptions": {
    "target": "ES2022",
    // "module": "NodeNext",
    // "moduleResolution": "NodeNext",
    "module": "commonjs",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": ["src/**/*"]
}
